{
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-tailwindcss"
  ],
  "importOrder": [
    "^node",
    "^@tanstack/(.*)$",
    "^react",
    "<THIRD_PARTY_MODULES>",
    "^@/(.*)$",
    "^\\./",
    "^\\.\\./",
    "\\.css$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderCombineTypeAndValueImports": true
}
